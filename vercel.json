{
    "functions": {
        "api/lookup.js": {
            "maxDuration": 30
        },
        "api/book.js": {
            "maxDuration": 10
        },
        "api/track.js": {
            "maxDuration": 5
        }
    },
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        },
        {
            "source": "/offer",
            "destination": "/index.html"
        },
        {
            "source": "/embed",
            "destination": "/index.html"
        }
    ],
    "headers": [
        {
            "source": "/api/(.*)",
            "headers": [
                {
                    "key": "Access-Control-Allow-Origin",
                    "value": "*"
                },
                {
                    "key": "Access-Control-Allow-Methods",
                    "value": "POST, OPTIONS"
                },
                {
                    "key": "Access-Control-Allow-Headers",
                    "value": "Content-Type"
                }
            ]
        },
        {
            "source": "/embed",
            "headers": [
                {
                    "key": "X-Frame-Options",
                    "value": "ALLOW-FROM https://yassclean.com"
                },
                {
                    "key": "Content-Security-Policy",
                    "value": "frame-ancestors 'self' https://yassclean.com https://*.yassclean.com"
                }
            ]
        }
    ]
}